/**
 * API Key authentication interceptor.
 * Auto-generated from OpenAPI specification.
 */
class ApiKeyAuthInterceptor(
    private val headerName: String = "X-API-Key",
    private val validator: (String) -> Boolean = { true }
) : RequestInterceptor {

    override fun beforeHandle(request: ApiRequest) {
        val apiKey = request.getHeader(headerName)
