package {{apiPackage}}.interceptor

import {{apiPackage}}.protocol.ApiRequest
import {{apiPackage}}.exception.ApiException
import java.util.Base64

/**
 * Basic HTTP authentication interceptor.
 * Auto-generated from OpenAPI specification.
 */
class BasicAuthInterceptor(
    private val validator: (username: String, password: String) -> Boolean
) : RequestInterceptor {

    override fun beforeHandle(request: ApiRequest) {
        val authHeader = request.getHeader("Authorization")
            ?: throw ApiException(401, "Missing Authorization header")
        if (!authHeader.startsWith("Basic ", ignoreCase = true)) {
            throw ApiException(401, "Invalid Authorization header format, expected: Basic <credentials>")
        }
        val decoded = try {
            String(Base64.getDecoder().decode(authHeader.substring(6)))
        } catch (e: Exception) {
            throw ApiException(401, "Invalid Base64 encoding in Authorization header")
        }
        val parts = decoded.split(":", limit = 2)
        if (parts.size != 2) {
            throw ApiException(401, "Invalid Basic auth format, expected: username:password")
        }
        if (!validator(parts[0], parts[1])) {
            throw ApiException(403, "Invalid credentials")
        }
    }
}
