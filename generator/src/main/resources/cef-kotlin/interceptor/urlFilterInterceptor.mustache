package {{apiPackage}}.interceptor

import {{apiPackage}}.protocol.ApiRequest
import {{apiPackage}}.exception.ApiException

/**
 * URL filter interceptor - restricts requests to allowed URL prefixes.
 * Auto-generated from OpenAPI specification.
 */
class UrlFilterInterceptor(private val allowedPrefixes: List<String>) : RequestInterceptor {

    override fun beforeHandle(request: ApiRequest) {
        val path = request.path
        if (allowedPrefixes.isNotEmpty() && allowedPrefixes.none { path.startsWith(it) }) {
            throw ApiException(403, "URL not allowed: $path")
        }
    }
}
