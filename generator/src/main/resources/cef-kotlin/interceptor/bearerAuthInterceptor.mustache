package {{apiPackage}}.interceptor

import {{apiPackage}}.protocol.ApiRequest
import {{apiPackage}}.exception.ApiException

/**
 * Bearer token (JWT) authentication interceptor.
 * Auto-generated from OpenAPI specification.
 */
class BearerAuthInterceptor(
    private val validator: (String) -> Boolean = { true }
) : RequestInterceptor {

    override fun beforeHandle(request: ApiRequest) {
        val authHeader = request.getHeader("Authorization")
            ?: throw ApiException(401, "Missing Authorization header")
        if (!authHeader.startsWith("Bearer ", ignoreCase = true)) {
            throw ApiException(401, "Invalid Authorization header format, expected: Bearer <token>")
        }
        val token = authHeader.substring(7)
        if (!validator(token)) {
            throw ApiException(403, "Invalid bearer token")
        }
    }
}
