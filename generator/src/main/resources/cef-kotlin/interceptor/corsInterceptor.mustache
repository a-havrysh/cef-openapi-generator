package {{apiPackage}}.interceptor

import {{apiPackage}}.protocol.ApiRequest
import {{apiPackage}}.exception.ApiException

/**
 * CORS interceptor - validates request origins against allowed list.
 * Auto-generated from OpenAPI specification.
 */
class CorsInterceptor(val allowedOrigins: List<String> = emptyList()) : RequestInterceptor {

    override fun beforeHandle(request: ApiRequest) {
        val origin = request.getHeader("Origin") ?: return
        if (allowedOrigins.isNotEmpty() && origin !in allowedOrigins) {
            throw ApiException(403, "Origin not allowed: $origin")
        }
    }
}
