package {{apiPackage}}.protocol

/**
 * HTTP response wrapper with status code, body, content type, and headers.
 *
 * Immutable — builder methods return new instances.
 *
 * ```kotlin
 * ApiResponse.ok(user)
 * ApiResponse.created(user).header("Location", "/users/${user.id}")
 * ApiResponse.noContent()
 * ApiResponse.status(202, "Accepted")
 * ```
 */
class ApiResponse<T>(
    val body: T,
    val contentType: String = "application/json",
    val statusCode: Int = 200,
    val headers: Map<String, String> = emptyMap()
) {
    /** Returns a copy with a different content type. */
    fun contentType(contentType: String) = ApiResponse(body, contentType, statusCode, headers)

    /** Returns a copy with an additional header. */
    fun header(name: String, value: String) = ApiResponse(body, contentType, statusCode, headers + (name to value))

    companion object {
        fun <T> ok(body: T) = ApiResponse(body)
        fun <T> ok(body: T, contentType: String) = ApiResponse(body, contentType)
        fun noContent() = ApiResponse<Unit?>(null, "text/plain", 204)
        fun <T> status(statusCode: Int, body: T) = ApiResponse(body, statusCode = statusCode)
        fun <T> created(body: T) = ApiResponse(body, statusCode = 201)
        fun notFound(message: String) = ApiResponse(message, statusCode = 404)
        fun badRequest(message: String) = ApiResponse(message, statusCode = 400)
        fun internalServerError(message: String) = ApiResponse(message, statusCode = 500)
    }
}
