package {{apiPackage}}.exception

/**
 * HTTP 400 with detailed validation errors.
 *
 * Thrown when request parameters violate OpenAPI constraints (required, minLength, pattern, etc.).
 */
class ValidationException(
    val errors: List<ValidationError>,
    message: String = buildMessage(errors)
) : BadRequestException(message) {

    data class ValidationError(
        val parameter: String,
        val value: Any?,
        val constraint: String,
        val message: String
    ) {
        override fun toString() = "$message (parameter: $parameter, constraint: $constraint)"
    }

    companion object {
        private fun buildMessage(errors: List<ValidationError>) = when {
            errors.isEmpty() -> "Validation failed"
            errors.size == 1 -> errors.first().message
            else -> "Validation failed with ${errors.size} error(s)"
        }
    }
}
